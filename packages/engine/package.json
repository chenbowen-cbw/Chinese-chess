{
  "name": "@xiangqi/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pure-TypeScript Xiangqi rules engine: board, move generation, rules, check/checkmate, FEN.",
  "main": "./src/index.ts",
